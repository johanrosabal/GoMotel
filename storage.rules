rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Permitir lectura pública para imágenes de la landing y galería
      allow read: if true;
      
      // Solo usuarios autenticados pueden subir o modificar archivos
      allow write: if request.auth != null;
    }
  }
}
