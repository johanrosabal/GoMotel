/**
 * WARNING: PERMISSIVE DEVELOPMENT RULES
 *
 * These rules are intentionally open to allow for rapid development and
 * to support server-side actions that run unauthenticated in this
 * specific prototyping environment.
 *
 * ANYONE can read, write, and delete ANY data in your database.
 *
 * DO NOT use these rules in a production environment. Before deploying
 * to production, you MUST secure your database.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow access to each collection to avoid wildcard issues.
    match /clients/{docId} { allow read, write: if true; }
    match /rooms/{docId} { allow read, write: if true; }
    match /roomTypes/{docId} { allow read, write: if true; }
    match /reservations/{docId} { allow read, write: if true; }
    match /stays/{docId} { allow read, write: if true; }
    match /orders/{docId} { allow read, write: if true; }
    match /services/{docId} { allow read, write: if true; }
    match /transactions/{docId} { allow read, write: if true; }
    match /users/{docId} { allow read, write: if true; }
    match /roles_admin/{docId} { allow read, write: if true; }
  }
}
