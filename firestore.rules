rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if a user has an admin role document.
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    // Function to check if a user document has a specific role.
    function hasRole(role) {
      let userProfile = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userProfile.role == role;
    }
    
    // Function to check if the user is an Admin or Reception staff.
    function isStaff() {
      return isAdmin() || hasRole('Recepcion');
    }
    
    // Function to check if the user is the owner of the document.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Admin role management. Only other admins can manage roles.
    match /roles_admin/{uid} {
      allow read, write: if isAdmin();
    }
    
    // User Profiles: Users can create/read their own profile. Admins can manage any profile.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Room Types are managed by Admins only, but readable by any authenticated user.
    match /roomTypes/{roomTypeId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }
    
    // Rooms are readable by any authenticated user, but managed by Admins.
    match /rooms/{roomId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
    
    // Services are readable by any authenticated user, but managed by Admins.
    match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
    
    // Reservations are readable by any authenticated user, but managed by staff.
    match /reservations/{reservationId} {
        allow read: if request.auth != null;
        allow write: if isStaff();
    }
    
    // Stays are readable by any authenticated user, but managed by staff.
    match /stays/{stayId} {
        allow read: if request.auth != null;
        allow write: if isStaff();
    }
    
    // Orders are readable by any authenticated user, but managed by staff.
    match /orders/{orderId} {
        allow read: if request.auth != null;
        allow write: if isStaff();
    }
    
    // Clients are readable by any authenticated user, but managed by staff.
    match /clients/{clientId} {
        allow read: if request.auth != null;
        allow write: if isStaff();
    }
    
    // Transactions are managed by Admins.
    match /transactions/{transactionId} {
      allow read, write: if isAdmin();
    }
  }
}
