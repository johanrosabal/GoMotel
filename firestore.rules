/**
 * Production-ready security rules for Go Motel.
 *
 * Core Philosophy:
 * Access is restricted by default. Only authenticated users with the 'admin'
 * role can perform read and write operations on the main data collections.
 * Role management is secured to prevent unauthorized privilege escalation.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the requesting user has the 'admin' role by checking for
     * a corresponding document in the 'roles_admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    // Read/write access for authenticated users during development
    match /rooms/{roomId} {
      allow read, write: if isSignedIn();
    }

    match /services/{serviceId} {
      allow read, write: if isSignedIn();
    }

    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    match /roomTypes/{roomTypeId} {
      allow read, write: if isSignedIn();
    }

    match /stays/{stayId} {
      allow read, write: if isSignedIn();
    }

    // Rules for the 'roles_admin' collection
    match /roles_admin/{uid} {
      // Admins can see who other admins are.
      allow get: if isAdmin();
      
      // Allow any authenticated user to check for existing admins during registration.
      // The `register` server action contains the logic to only make the first user an admin.
      allow list: if isSignedIn();
      
      // Allow a user to create their own admin role document.
      // The server action logic ensures this only happens for the first registered user.
      allow create: if request.auth.uid == uid;

      // Prevent users from updating or deleting roles.
      allow update, delete: if false;
    }
  }
}
