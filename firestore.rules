/**
 * This ruleset has been temporarily relaxed for development purposes.
 *
 * Core Philosophy:
 * The security model is currently configured to allow any authenticated user to
 * perform read and write operations. This is achieved by modifying the `isAdmin()`
 * function to simply check if a user is signed in (`isSignedIn()`).
 *
 * FOR PRODUCTION: You must revert this change and implement a robust role-based
 * system. The original `isAdmin()` function checked for the existence of a
 * document in the `/roles_admin` collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * TEMPORARY DEVELOPMENT RULE: For now, any signed-in user is an admin.
     * TODO: Revert to a proper role check for production.
     * e.g., return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
     */
    function isAdmin() {
      return isSignedIn();
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /rooms/{roomId} {
      allow read, write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read, write: if isAdmin();
    }

    match /roomTypes/{roomTypeId} {
      allow read, write: if isAdmin();
    }

    match /stays/{stayId} {
      allow read, write: if isAdmin();
    }

    // Lock down the roles collection from client-side writes.
    match /roles_admin/{uid} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
