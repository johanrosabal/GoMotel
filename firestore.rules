rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Abierto para desarrollo: Permite el acceso de lectura y escritura a cualquiera.
    // Esto elimina las barreras de permisos durante la creación de prototipos.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
