
{
  "entities": {
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Represents a registered guest/client of the motel.",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "Client's first name."
        },
        "lastName": {
          "type": "string",
          "description": "Client's primary last name."
        },
        "secondLastName": {
          "type": "string",
          "description": "Client's secondary last name."
        },
        "idCard": {
          "type": "string",
          "description": "Client's national identity card number."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Client's email address."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Client's phone number."
        },
        "whatsappNumber": {
          "type": "string",
          "description": "Client's WhatsApp number."
        },
        "birthDate": {
          "type": "string",
          "format": "date-time",
          "description": "Client's date of birth."
        },
        "address": {
          "type": "string",
          "description": "Client's address."
        },
        "notes": {
          "type": "string",
          "description": "Internal notes about the client."
        },
        "isVip": {
          "type": "boolean",
          "description": "Indicates if the client is a VIP."
        },
        "visitCount": {
          "type": "number",
          "description": "Total number of visits to the motel."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the client was registered."
        }
      },
      "required": [
        "firstName",
        "lastName",
        "idCard",
        "email",
        "phoneNumber",
        "createdAt"
      ]
    },
    "Reservation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Reservation",
      "type": "object",
      "description": "Represents a future booking for a room.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Reservation entity."
        },
        "roomId": {
          "type": "string",
          "description": "Reference to the Room being reserved."
        },
        "roomNumber": {
          "type": "string",
          "description": "Denormalized room number for display."
        },
        "roomType": {
          "type": "string",
          "description": "Denormalized room type name for display."
        },
        "guestName": {
          "type": "string",
          "description": "Name of the primary guest."
        },
        "guestId": {
          "type": "string",
          "description": "Reference to the UserProfile of the guest, if available."
        },
        "checkInDate": {
          "type": "string",
          "format": "date-time",
          "description": "The expected check-in date and time."
        },
        "checkOutDate": {
          "type": "string",
          "format": "date-time",
          "description": "The expected check-out date and time."
        },
        "status": {
          "type": "string",
          "description": "The status of the reservation.",
          "enum": [
            "Confirmed",
            "Checked-in",
            "Cancelled",
            "No-show"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the reservation was created."
        },
        "paymentMethod": {
          "type": "string",
          "description": "Payment method chosen for the reservation.",
          "enum": [
            "Efectivo",
            "Sinpe Movil",
            "Tarjeta",
            "Por Definir"
          ]
        },
        "paymentStatus": {
          "type": "string",
          "description": "Payment status of the reservation.",
          "enum": [
            "Pagado",
            "Pendiente"
          ]
        },
        "paymentAmount": {
          "type": "number",
          "description": "The amount paid for the reservation, if any."
        }
      },
      "required": [
        "id",
        "roomId",
        "roomNumber",
        "roomType",
        "guestName",
        "checkInDate",
        "checkOutDate",
        "status",
        "createdAt"
      ]
    },
    "Room": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Room",
      "type": "object",
      "description": "Represents a room in the motel.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Room entity."
        },
        "number": {
          "type": "string",
          "description": "The room number or identifier."
        },
        "status": {
          "type": "string",
          "description": "The current status of the room (e.g., available, occupied, out of service)."
        },
        "roomTypeId": {
          "type": "string",
          "description": "Reference to the RoomType entity."
        },
        "roomTypeName": {
          "type": "string",
          "description": "Denormalized name of the RoomType."
        },
        "type": {
          "type": "string",
          "description": "Denormalized name of the RoomType. Kept for compatibility."
        },
        "capacity": {
          "type": "number",
          "description": "Capacity of the room."
        },
        "description": {
          "type": "string",
          "description": "Description of the room, based on RoomType features."
        },
        "ratePerHour": {
          "type": "number",
          "description": "Hourly rate, based on RoomType price plans."
        }
      },
      "required": [
        "id",
        "number",
        "status",
        "roomTypeId",
        "roomTypeName",
        "type",
        "capacity",
        "ratePerHour"
      ]
    },
    "RestaurantTable": {
      "title": "Restaurant Table",
      "type": "object",
      "description": "Represents a physical table or spot in the restaurant/bar.",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "type": { "type": "string", "enum": ["Table", "Bar"] },
        "status": { "type": "string", "enum": ["Available", "Occupied"] },
        "currentOrderId": { "type": "string" }
      },
      "required": ["number", "type", "status"]
    },
    "Service": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Service",
      "type": "object",
      "description": "Represents a service offered by the motel (e.g., food, drinks).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Service entity."
        },
        "code": {
          "type": "string",
          "description": "A unique, auto-incrementing code for the product (e.g., P001)."
        },
        "name": {
          "type": "string",
          "description": "The name of the service (e.g., bottled water, sandwich)."
        },
        "description": {
          "type": "string",
          "description": "A description of the service."
        },
        "price": {
          "type": "number",
          "description": "The sale price of the service."
        },
        "costPrice": {
          "type": "number",
          "description": "The cost price of the service."
        },
        "stock": {
          "type": "number",
          "description": "The current available quantity of the service."
        },
        "minStock": {
          "type": "number",
          "description": "The minimum stock level before it is considered low stock."
        },
        "imageUrl": {
          "type": "string",
          "description": "Data URI for the product's image."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the product is active and available for sale."
        },
        "taxIds": {
          "type": "array",
          "description": "A list of tax IDs applicable to this service.",
          "items": {
            "type": "string"
          }
        },
        "supplierId": {
          "type": "string",
          "description": "Reference to the Supplier of this product."
        },
        "supplierName": {
          "type": "string",
          "description": "Denormalized name of the supplier for display."
        },
        "source": {
          "type": "string",
          "description": "Indicates if the product is purchased from a supplier or produced internally.",
          "enum": [
            "Purchased",
            "Internal"
          ],
          "default": "Purchased"
        }
      },
      "required": [
        "id",
        "name",
        "price"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents an order for services.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order entity."
        },
        "locationType": {
          "type": "string",
          "enum": ["Stay", "Table", "Bar", "Takeout"],
          "description": "Where this order is being served."
        },
        "locationId": {
          "type": "string",
          "description": "The ID of the room stay or restaurant table."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "serviceId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "Pendiente",
            "En preparación",
            "Entregado",
            "Cancelado"
          ]
        },
        "total": {
          "type": "number",
          "description": "The total price of the order."
        }
      },
      "required": [
        "items",
        "createdAt",
        "status",
        "total"
      ]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User's unique ID from Firebase Auth."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address."
        },
        "firstName": {
          "type": "string",
          "description": "User's first name."
        },
        "lastName": {
          "type": "string",
          "description": "User's primary last name."
        },
        "secondLastName": {
          "type": "string",
          "description": "User's secondary last name."
        },
        "birthDate": {
          "type": "string",
          "format": "date-time",
          "description": "User's date of birth."
        },
        "idCard": {
          "type": "string",
          "description": "User's national identity card number."
        },
        "phoneNumber": {
          "type": "string",
          "description": "User's primary phone number."
        },
        "whatsappNumber": {
          "type": "string",
          "description": "User's WhatsApp number, if different from phone."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the profile was created."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the application.",
          "enum": [
            "Administrador",
            "Recepcion",
            "Conserje",
            "Contador"
          ]
        },
        "status": {
          "type": "string",
          "description": "The current status of the user's account.",
          "enum": [
            "Active",
            "Paused"
          ]
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        }
      },
      "required": [
        "uid",
        "email",
        "firstName",
        "lastName",
        "birthDate",
        "idCard",
        "phoneNumber",
        "createdAt",
        "role",
        "status"
      ]
    },
    "Tax": {
      "title": "Tax",
      "type": "object",
      "description": "Represents a tax rate applicable to services or products.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Tax."
        },
        "name": {
          "type": "string",
          "description": "The name of the tax (e.g., IVA, Sales Tax)."
        },
        "percentage": {
          "type": "number",
          "description": "The tax rate as a percentage (e.g., 13 for 13%)."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the tax."
        }
      },
      "required": [
        "name",
        "percentage"
      ]
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "description": "Represents a billing document for a reservation or a stay.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Invoice."
        },
        "invoiceNumber": {
          "type": "string",
          "description": "Sequential invoice number, e.g., FAC-00001."
        },
        "reservationId": {
          "type": "string",
          "description": "Reference to the associated Reservation. Optional for direct sales."
        },
        "stayId": {
          "type": "string",
          "description": "Reference to the associated Stay, if applicable."
        },
        "clientId": {
          "type": "string",
          "description": "Reference to the Client, if available."
        },
        "clientName": {
          "type": "string",
          "description": "Name of the client being billed."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the invoice was generated."
        },
        "status": {
          "type": "string",
          "enum": [
            "Pagada",
            "Pendiente",
            "Anulada"
          ],
          "description": "The current status of the invoice."
        },
        "items": {
          "type": "array",
          "description": "List of billable items on the invoice.",
          "items": {
            "$ref": "#/backend/entities/InvoiceItem"
          }
        },
        "subtotal": {
          "type": "number",
          "description": "The total amount before taxes."
        },
        "taxes": {
          "type": "array",
          "description": "List of taxes applied to the invoice.",
          "items": {
            "$ref": "#/backend/entities/AppliedTax"
          }
        },
        "total": {
          "type": "number",
          "description": "The final amount of the invoice, including taxes."
        },
        "paymentMethod": {
          "type": "string",
          "description": "The method of payment used.",
          "enum": [
            "Efectivo",
            "Sinpe Movil",
            "Tarjeta"
          ]
        }
      },
      "required": [
        "invoiceNumber",
        "clientName",
        "createdAt",
        "status",
        "items",
        "subtotal",
        "total"
      ]
    },
    "InvoiceItem": {
      "title": "Invoice Item",
      "type": "object",
      "description": "A single line item on an invoice.",
      "properties": {
        "description": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "unitPrice": {
          "type": "number"
        },
        "total": {
          "type": "number"
        }
      },
      "required": [
        "description",
        "quantity",
        "unitPrice",
        "total"
      ]
    },
    "AppliedTax": {
      "title": "Applied Tax",
      "type": "object",
      "description": "A tax that is applied to an invoice.",
      "properties": {
        "taxId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "percentage": {
          "type": "number"
        },
        "amount": {
          "type": "number"
        }
      },
      "required": [
        "taxId",
        "name",
        "percentage",
        "amount"
      ]
    },
    "SinpeAccount": {
      "title": "SINPE Account",
      "type": "object",
      "description": "Represents a SINPE Movil account for receiving payments.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the SINPE account."
        },
        "accountHolder": {
          "type": "string",
          "description": "The name of the account holder."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The phone number associated with the SINPE account."
        },
        "bankName": {
          "type": "string",
          "description": "The name of the bank where the account is held."
        },
        "balance": {
          "type": "number",
          "description": "The current balance of the SINPE account."
        },
        "limitAmount": {
          "type": "number",
          "description": "The monthly limit amount for this account."
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the account is active for receiving payments."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the account was added."
        }
      },
      "required": [
        "accountHolder",
        "phoneNumber",
        "bankName",
        "balance",
        "isActive",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/restaurantTables/{tableId}",
        "definition": {
          "entityName": "RestaurantTable",
          "schema": { "$ref": "#/backend/entities/RestaurantTable" },
          "description": "Stores state of restaurant tables and bar spots.",
          "params": [{ "name": "tableId", "description": "Unique ID" }]
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Stores information about orders. Linked to room stays or restaurant locations.",
          "params": [
            {
              "name": "orderId",
              "description": "The unique identifier of the order."
            }
          ]
        }
      }
    ]
  }
}
